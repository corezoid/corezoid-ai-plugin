            {"type": "go", "to_node_id": "gitc000000000000000000007"}
          ],
          "semaphors": [
            {
              "type": "time",
              "value": 10,
              "dimension": "min",
              "to_node_id": "gitc000000000000000000003"
            }
          ]
        },
        "title": "Execute Risk Score Script",
        "description": "Pulls and runs the risk-scoring algorithm from the main branch. Returns risk_score and risk_factors.",
        "x": 400, "y": 100,
        "extra": "{\"modeForm\":\"expand\",\"icon\":\"\"}",
        "options": null
      },
      {
        "id": "gitc000000000000000000003",
        "obj_type": 0,
        "condition": {
          "logics": [
            {
              "type": "go_if_const",
              "to_node_id": "gitc000000000000000000004",
              "conditions": [
                {
                  "param": "__conveyor_git_call_return_type_error__",
                  "const": "hardware",
                  "fun": "eq",
                  "cast": "string"
                }
              ]
            },
            {"type": "go", "to_node_id": "gitc000000000000000000006"}
          ],
          "semaphors": []
        },
        "title": "Check Git Error Type",
        "description": "Routes network/access errors to retry, code runtime errors to failure node",
        "x": 700, "y": 100,
        "extra": "{\"modeForm\":\"expand\",\"icon\":\"\"}",
        "options": null
      },
      {
        "id": "gitc000000000000000000004",
