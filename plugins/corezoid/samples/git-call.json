              "value": 30,
              "dimension": "sec",
              "to_node_id": "gitc000000000000000000002"
            }
          ]
        },
        "title": "Wait 30s Before Retry",
        "description": "Waits 30 seconds after a Git access or network error before retrying",
        "x": 700, "y": 300,
